  64:Core/Src/main.c **** void process_uart_command(void)
  65:Core/Src/main.c **** {
  66:Core/Src/main.c ****     // Проверяем, что команда начинается с 'd'
  67:Core/Src/main.c ****     if(rx_buffer[0] == 'd' || rx_buffer[0] == 'D')
  68:Core/Src/main.c ****     {
  69:Core/Src/main.c ****         char *ptr = (char*)rx_buffer;
  70:Core/Src/main.c ****         int value = 0;
  71:Core/Src/main.c ****         
  72:Core/Src/main.c ****         // Пропускаем 'd'
  73:Core/Src/main.c ****         ptr++;
  74:Core/Src/main.c ****         
  75:Core/Src/main.c ****         // Пропускаем пробелы
  76:Core/Src/main.c ****         while(*ptr == ' ') ptr++;
  77:Core/Src/main.c ****         
  78:Core/Src/main.c ****         // Парсим число
  79:Core/Src/main.c ****         while(*ptr >= '0' && *ptr <= '9')
  80:Core/Src/main.c ****         {
  81:Core/Src/main.c ****             value = value * 10 + (*ptr - '0');
  82:Core/Src/main.c ****             ptr++;
  83:Core/Src/main.c ****         }
  84:Core/Src/main.c ****         
  85:Core/Src/main.c ****         // Ограничиваем значение
  86:Core/Src/main.c ****         if(value > 1999) value = 1999;
  87:Core/Src/main.c ****         
  88:Core/Src/main.c ****         // Устанавливаем PWM
ARM GAS  C:\Users\andre\AppData\Local\Temp\ccOJ4t8l.s 			page 3


  89:Core/Src/main.c ****         TIM1->CCR1 = value;
  90:Core/Src/main.c ****         
  91:Core/Src/main.c ****         // Отправляем подтверждение
  92:Core/Src/main.c ****         char response[32];
  93:Core/Src/main.c ****         sprintf(response, "OK: %d\r\n", value);
  94:Core/Src/main.c ****         HAL_UART_Transmit(&huart1, (uint8_t*)response, strlen(response), 100);
  95:Core/Src/main.c ****     }
  96:Core/Src/main.c ****     
  97:Core/Src/main.c ****     // Очищаем буфер
  98:Core/Src/main.c ****     memset(rx_buffer, 0, sizeof(rx_buffer));
  99:Core/Src/main.c ****     rx_index = 0;
 100:Core/Src/main.c **** }
 101:Core/Src/main.c **** 
 102:Core/Src/main.c **** void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
 103:Core/Src/main.c **** {
 104:Core/Src/main.c ****     if(huart->Instance == USART1)
 105:Core/Src/main.c ****     {
 106:Core/Src/main.c ****         // Если Enter - обрабатываем команду
 107:Core/Src/main.c ****         if(rx_buffer[rx_index] == '\r' || rx_buffer[rx_index] == '\n')
 108:Core/Src/main.c ****         {
 109:Core/Src/main.c ****             rx_buffer[rx_index] = '\0';
 110:Core/Src/main.c ****             process_uart_command();
 111:Core/Src/main.c ****             HAL_UART_Transmit(&huart1, (uint8_t*)"\r\n> ", 4, 100);
 112:Core/Src/main.c ****             rx_index = 0;
 113:Core/Src/main.c ****             HAL_UART_Receive_IT(&huart1, &rx_buffer[0], 1);
 114:Core/Src/main.c ****         }
 115:Core/Src/main.c ****         else if(rx_index < sizeof(rx_buffer) - 1)
 116:Core/Src/main.c ****         {
 117:Core/Src/main.c ****             rx_index++;
 118:Core/Src/main.c ****             HAL_UART_Receive_IT(&huart1, &rx_buffer[rx_index], 1);
 119:Core/Src/main.c ****         }
 120:Core/Src/main.c ****         else
 121:Core/Src/main.c ****         {
 122:Core/Src/main.c ****             // Переполнение - сброс
 123:Core/Src/main.c ****             rx_index = 0;
 124:Core/Src/main.c ****             memset(rx_buffer, 0, sizeof(rx_buffer));
 125:Core/Src/main.c ****             HAL_UART_Receive_IT(&huart1, &rx_buffer[0], 1);
 126:Core/Src/main.c ****         }
 127:Core/Src/main.c ****     }
 128:Core/Src/main.c **** }
